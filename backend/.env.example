# Base de données locale PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/nma_primes

# SAP B1 - Connexion SQL Server
SAP_DB_TYPE=sqlserver            # sqlserver ou hana
SAP_SERVER=your_sap_server
SAP_DATABASE=SBODemoSenegal
SAP_USERNAME=sa
SAP_PASSWORD=your_password
SAP_PORT=1433
SAP_DRIVER=ODBC Driver 18 for SQL Server

# SAP B1 - Connexion HANA (si SAP_DB_TYPE=hana)
# SAP_HANA_HOST=your_hana_host
# SAP_HANA_PORT=39015
# SAP_HANA_USER=your_user
# SAP_HANA_PASSWORD=your_password

# Salesforce
SF_USERNAME=your_sf_username
SF_PASSWORD=your_sf_password
SF_SECURITY_TOKEN=your_sf_token
SF_DOMAIN=login

# App
APP_SECRET_KEY=change-this-in-production
ENVIRONMENT=development
