  employees [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD COLSPAN="3" BGCOLOR="#2E7D32" ALIGN="CENTER"><FONT COLOR="white" POINT-SIZE="11"><B>employees</B></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">🔑</FONT></TD><TD ALIGN="LEFT" PORT="id"><FONT COLOR="#C62828" POINT-SIZE="9"><B>id</B></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="nom"><FONT COLOR="#212121" POINT-SIZE="9">nom</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(100)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="prenom"><FONT COLOR="#212121" POINT-SIZE="9">prenom</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(100)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="type_poste"><FONT COLOR="#212121" POINT-SIZE="9">type_poste</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(12)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">⤷</FONT></TD><TD ALIGN="LEFT" PORT="region_id"><FONT COLOR="#1565C0" POINT-SIZE="9"><I>region_id</I></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">⤷</FONT></TD><TD ALIGN="LEFT" PORT="zone_id"><FONT COLOR="#1565C0" POINT-SIZE="9"><I>zone_id</I></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="actif"><FONT COLOR="#212121" POINT-SIZE="9">actif</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>BOOLEAN</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="sap_code"><FONT COLOR="#212121" POINT-SIZE="9">sap_code</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(50)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="sf_id"><FONT COLOR="#212121" POINT-SIZE="9">sf_id</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(50)</I></FONT></TD></TR></TABLE>> color="#81C784"]
  users [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD COLSPAN="3" BGCOLOR="#455A64" ALIGN="CENTER"><FONT COLOR="white" POINT-SIZE="11"><B>users</B></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">🔑</FONT></TD><TD ALIGN="LEFT" PORT="id"><FONT COLOR="#C62828" POINT-SIZE="9"><B>id</B></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="email"><FONT COLOR="#212121" POINT-SIZE="9">email</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(200)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="hashed_password"><FONT COLOR="#212121" POINT-SIZE="9">hashed_password</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(300)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="nom"><FONT COLOR="#212121" POINT-SIZE="9">nom</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(150)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="role"><FONT COLOR="#212121" POINT-SIZE="9">role</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(50)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="actif"><FONT COLOR="#212121" POINT-SIZE="9">actif</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>BOOLEAN</I></FONT></TD></TR></TABLE>> color="#B0BEC5"]
