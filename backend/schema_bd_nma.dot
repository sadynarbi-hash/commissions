digraph NMA_BD {
  graph [
    rankdir=LR
    splines=ortho
    nodesep=0.6
    ranksep=1.2
    fontname="Helvetica"
    fontsize=12
    label="Schéma Base de Données — NMA Gestion des Primes 2026"
    labelloc=t
    labeljust=c
    bgcolor="#FAFAFA"
  ]
  node [shape=none margin=0 fontname="Helvetica"]
  edge [fontname="Helvetica" fontsize=8 arrowhead=crow arrowtail=none dir=forward color="#607D8B"]

  subgraph cluster_geo {
    graph [label="Référentiel géographique" bgcolor="#E8F5E9" style=rounded pencolor="#B0BEC5" penwidth=1.5 fontname="Helvetica-Bold" fontsize=10]
  regions [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD COLSPAN="3" BGCOLOR="#1B5E20" ALIGN="CENTER"><FONT COLOR="white" POINT-SIZE="11"><B>regions</B></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">🔑</FONT></TD><TD ALIGN="LEFT" PORT="id"><FONT COLOR="#C62828" POINT-SIZE="9"><B>id</B></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="nom"><FONT COLOR="#212121" POINT-SIZE="9">nom</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(100)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="type"><FONT COLOR="#212121" POINT-SIZE="9">type</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(9)</I></FONT></TD></TR></TABLE>> color="#4CAF50"]
  zones [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD COLSPAN="3" BGCOLOR="#1B5E20" ALIGN="CENTER"><FONT COLOR="white" POINT-SIZE="11"><B>zones</B></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">🔑</FONT></TD><TD ALIGN="LEFT" PORT="id"><FONT COLOR="#C62828" POINT-SIZE="9"><B>id</B></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="code"><FONT COLOR="#212121" POINT-SIZE="9">code</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(10)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9"> </FONT></TD><TD ALIGN="LEFT" PORT="nom"><FONT COLOR="#212121" POINT-SIZE="9">nom</FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>VARCHAR(50)</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">⤷</FONT></TD><TD ALIGN="LEFT" PORT="superviseur_id"><FONT COLOR="#1565C0" POINT-SIZE="9"><I>superviseur_id</I></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR><TR><TD ALIGN="LEFT" WIDTH="14"><FONT POINT-SIZE="9">⤷</FONT></TD><TD ALIGN="LEFT" PORT="responsable_id"><FONT COLOR="#1565C0" POINT-SIZE="9"><I>responsable_id</I></FONT></TD><TD ALIGN="LEFT"><FONT COLOR="#607D8B" POINT-SIZE="8"><I>INTEGER</I></FONT></TD></TR></TABLE>> color="#4CAF50"]
